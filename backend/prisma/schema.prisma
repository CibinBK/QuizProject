// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  quizzes   Quiz[]
}

model Quiz {
  id          String     @id @default(uuid())
  title       String
  description String?
  hostId      String
  host        User       @relation(fields: [hostId], references: [id])
  questions   Question[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Question {
  id            String   @id @default(uuid())
  text          String
  imageUrl      String?
  type          String   @default("MULTIPLE_CHOICE") // MULTIPLE_CHOICE, TRUE_FALSE, TYPE_ANSWER
  options       String   // Stored as JSON string (e.g., '["A", "B", "C", "D"]')
  correctAnswer Int      // Index of the correct option (0-3)
  readTime      Int      @default(5)  // Seconds for the "Get Ready" buffer
  timeLimit     Int      @default(20) // Seconds for answering
  points        Int      @default(1000)
  section       String?  // Optional section/round name
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}
